* {
    box-sizing: border-box;
    
}
body{
    background-color: #D9D9D9;
    font-family: 'Noto Sans', sans-serif;
}
.container{
    background-color: #697777;
    width: 1000px;
    height: auto;
    margin: auto;
    overflow: hidden;
}
header{
    background-color: #292929;
    width: 1000px;
    height: 150px;
}
.logo{
    background-color: aquamarine;
    width: 800px;
    height: 150px;
    margin-left: 100px;
}
img{
    width: 100%;
    height: 100%;
}
.left{
    background-color: #292929;
    width: 200px;
    height: auto;
    margin-left: 20px;
    margin-top: 20px;
    margin-bottom: 20px;
    float: left;
}
.right{
    background-color: #292929;
    width: 740px;
    height: auto;
    margin-left: 20px;
    margin-top: 20px;
    margin-bottom: 20px;
    float: left;
}
.title{
    width: 740px;
    height: auto;
    background-color: #697777;
    float: left;
    padding: 20px;
}
h2 {
   text-align: center;
   color: black;
}
.banner{
    width: 740px;
    height: 200px;
    background-color: #E27828;
    float: left;
}
.text{
    width: 100%;
    height: auto;
    float: left;
    padding: 20px;
    margin-top: 0px;
    color: white;
}
.space{
    margin-top: 25px;
}
ul {
  list-style-type: none;
  margin: 0;
  padding: 0;
  width: 200px;
  background-color: #E27828;
    border: 1px solid #555;
}

li a {
  display: block;
  color: #000;
  padding: 8px 16px;
  text-decoration: none;
  text-align: center;
  border-bottom: 1px solid #fff;
    font-weight: 800;
}
a:visited { 
 text-decoration: none; 
 color: white; 
}
/* Change the link color on hover */
li a:hover {
  background-color: #555;
  color: white;
}
li:last-child {
    border-bottom: none;
}